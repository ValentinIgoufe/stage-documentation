{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "description": "Ma cnfiguration",
  "fetchChangeLogs": "pr",
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "recreateWhen": "always",
  "rebaseWhen": "behind-base-branch",
  "rangeStrategy": "in-range-only",
  "separateMajorMinor": false,
  "composerIgnorePlatformReqs": ["ext-*", "lib-*", "php"],
  "packageRules": [
    {
      "description": "PHP Dockerfile",
      "groupName": "MAJ PHP Dockerfile",
      "matchPackageNames": ["php", "docker.io/library/php", "php-fpm"],
      "matchDatasources": ["docker"],
      "rangeStrategy": "bump",
      "allowedVersions": "< 8.5.0"
    },
    {
      "matchManagers": ["composer", "npm"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "description": "Grouper les de mises à jour non majeures",
      "groupName": "Mises à jour non majeures",
      "excludePackageNames": ["php", "docker.io/library/php", "php-fpm"],
      "postUpdateOptions": ["composerWithAll", "npmDedupe"]
    },
    {
      "description": "MAJ Majeures",
      "groupName": "Mises à jour majeures",
      "excludePackageNames": ["php", "docker.io/library/php", "php-fpm"],
      "dependencyDashboardApproval": true,
      "fetchChangeLogs": "off",
      "rangeStrategy": "bump" 
    },
    {
      "description": "Labels pour le Backend JS",
      "matchManagers": ["npm"],
      "matchFileNames": ["package.json"],
      "labels": ["javascript"]
    },
    {
      "description": "Labels pour le Backend PHP",
      "matchManagers": ["composer"],
      "matchFileNames": ["composer.json"],
      "labels": ["php"]
    },
    {
      "description": "Labels pour les Dockerfiles",
      "matchFileNames": ["Dockerfile"],
      "labels": ["docker"]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["\\.gitlab-ci\\.ya?ml$"],
      "matchStrings": [
        "remote:\\s+https://gitlab/mon-groupe/renovate-bot/-/raw/(?<currentValue>v[0-9.]+)/"
      ],
      "datasourceTemplate": "gitlab-releases",
      "depNameTemplate": "mon-groupe/renovate-bot"
    }
  ]
}